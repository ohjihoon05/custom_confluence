#if(false)
<?xml version="1.0" encoding="UTF-8"?>
#end
<svg
     version="1.1"
     #if ($width)
     width="$width"
     #end
     #if ($height)
     height="$height"
     #end
     viewBox="0 0 $viewboxWidth $viewboxHeight"
     xmlns="http://www.w3.org/2000/svg"
     xmlns:xlink="http://www.w3.org/1999/xlink"
     role="img"
     aria-label="$iconName"
>
    <path fill="$color" d="$path"> </path>
</svg>